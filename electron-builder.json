{
  "appId": "com.xenomorph.spotify.discordrpc",
  "productName": "Spotify Discord RPC",
  "directories": {
    "output": "release"
  },
  "win": {
    "icon": "assets/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Spotify Discord RPC"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ]
}
